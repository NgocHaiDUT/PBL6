                "userid" : 1,
                "staffemail" : "nguyenhai842003@gmail.com",
                "shopid" : 2,
                "is_manager" : false
            },
            "expectedResult" : {
                "success" : false,
                "message" : "Bạn không có quyền thêm nhân viên"
            },
            "mockSetup": {
                "permission.findUnique": { "id": 1 },
                "users.findUnique" : {"id" : 3, "email" : "nguyenhai842003@gmail.com"},
                "userpermission.findFirst": null
            }
        },
        {
            "testCaseId" : "TC_AS_03",
            "testCaseDescription" : "Thêm nhân viên thất bại nếu hệ thống không có quyền manage_shop_staff",
            "input" : {
                "userid" : 1,
                "staffemail" : "nguyenhai842003@gmail.com",
                "shopid" : 2,
                "is_manager" : false
            },
            "expectedResult" : {
                "success" : false,
                "message" : "Lỗi hệ thống, quyền manage_shop_staff không tồn tại"
            },
            "mockSetup": {
                "permission.findUnique": null
            }
        },
        {
            "testCaseId" : "TC_AS_04",
