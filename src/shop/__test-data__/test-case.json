{
    "addstaff" : [
        {
            "testCaseId" : "TC_AS_01",
            "testCaseDescription" : "Thêm nhân viên thành công",
            "input" : {
                "userid" : 1,
                "staffemail" : "nguyenhai842003@gmail.com",
                "shopid" : 2,
                "is_manager" : false
            },
            "expectedResult" : {
                "success" : true,
                "message" : "Thêm nhân viên thành công"
            },
            "mockSetup": {
                "permission.findUnique": { "id": 1 },
                "userpermission.findFirst": { "user_id": 1 },
                "users.findUnique": { "id": 3, "email": "nguyenhai842003@gmail.com" },
                "shops.findUnique": { "owner_id": 1 },
                "shop_staffs.findFirst": [null, null],
                "role.findUnique": {
                    "id": 2,
                    "name": "staff",
                    "rolePermissions": [{ "permission_id": 10 }, { "permission_id": 11 }]
                },
                "$transaction": true
            }
        },
        {
            "testCaseId" : "TC_AS_02",
            "testCaseDescription" : "Thêm nhân viên thất bại nếu người thêm không có quyền manage_shop_staff",
