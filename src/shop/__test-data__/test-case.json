            "mockSetup": {
                "permission.findUnique": { "id": 1 },
                "userpermission.findFirst": { "user_id": 1 },
                "users.findUnique": null,
                "shops.findUnique": { "owner_id": 1 },
                "shop_staffs.findFirst": null
            }
        },
        {
            "testCaseId" : "TC_AS_06",
