            "mockSetup": {
                "permission.findUnique": { "id": 1 },
                "userpermission.findFirst": { "user_id": 1 },
                "users.findUnique": { "id": 3, "email": "nguyenhai842003@gmail.com" },
                "shops.findUnique": null
            }
        },
        {
            "testCaseId" : "TC_AS_05",
